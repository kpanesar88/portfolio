# Ignore NodeModules
node_modules/

# Ignore compiled CSS file in the css folder (if it's generated by Tailwind)
css/stylesheet.css

# Ignore any logs, temporary files, or system-specific files
*.log

# Ignore environment files (like .env, if you have any)
.env
.env.local

# Ignore the output folder for Tailwind (if you're using a build folder like 'dist' or 'public')
dist/
public/

# Ignore any other specific files or directories that don't need to be versioned
